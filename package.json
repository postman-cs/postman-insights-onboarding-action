{
  "name": "postman-insights-onboarding-action",
  "version": "0.1.0-beta.0",
  "description": "GitHub Action to onboard Postman Insights discovered services to API Catalog workspaces.",
  "type": "module",
  "main": "dist/index.cjs",
  "files": [
    "action.yml",
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.cjs",
    "check:dist": "npm run build && git diff --exit-code -- dist/index.cjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "github-action",
    "postman",
    "insights",
    "api-catalog"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  }
}
